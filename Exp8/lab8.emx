   ServoMotor1 328.9 132.5
    type ServoMotor
     ports
      rotation psi out p;
      signal in i {A} ;
     restrictions
      causality fixed in p;
    end;
    icon bg bottom
     figures
      rectangle 353.8 132.8 369.1 135.8 fill 15132390;
      rectangle 309.3 119 354.3 149 fill 15132390;
      line 349.8 119 349.8 149 fill 15132390;
      rectangle 354.3 121.5 357.3 145.5 fill 15132390;
      text 'DC' 328.8 127.5 color 16711680 14;
      text 'brushl' 330.8 139 color 16711680 14;
      line 309.2 134.8 301.7 134.8 fill 15132390;
      text 'i' 289.8 121 color 16711680 14;
      text 'max' 299.3 125 color 16711680;
     terminals
      p 368 134.5 fixed;
      i 300.5 134.5 fixed;
    end;
    implementation eq
// 20-sim User Editor
// MotorWizard.dll
// C:\Program Files (x86)\20-sim 4.5\Tools\Servo Motor Dynamics\Faulhaber 2006.cse
constants
	string Name = 'Faulhaber 4490-036BS';				// name of motor
	string Keyname = '4490-036BS';				// keyname of motor
	string Info = 'brushless';				// info of motor
/*	
	string Date = '38770';				/ / Date of entry
*/
parameters
/*
	real Price = 0 {euro};				/ / Price in Euro
	string Delivery_time = '0' {weeks};			/ / Delivery Time
	real U_rms_nom = 66.7118 {V}; 				/ / nominal motor voltage
	real P_nom = 209.859 {W};					/ / nominal power
	real Life_nom = 0 {hour};				/ / nominal Lifetime
	real F_axial = 0 {N};					/ / maximum axial force
	real F_radial = 0 {N};				/ / maximum radial force
	real m = 0{kg};					/ / motor mass
	real D_motor = 0.044 {m};					/ / motor diameter
	real L_motor = 0.09 {m};					/ / motor length
	real D_shaft = 0 {m};				/ / shaft diameter
	real L_shaft = 0 {m};				/ / shaft length
	real T_100 = 0 {N.m};					/ / maximum torque at 100% duty cycle
	real S = 0.00508159456233 {N.m.s/rad};				/ / motor steepness
	real K_nom = 0.08251870523416 {N.m/A};				/ / torque constant at nom current
	real K_max = 0.05895993776451 {N.m/A};				/ / torque constant at max current
	real tau_m = 0.0025582521077871 {s};					/ / mechanical time constant
	real tau_e = 0.00032462686567164 {s};					/ / electrical time constant
	real P_dis = 0 {W};					/ / dissipated internal power
	real tau_T1 = 29.000025 {s};					/ / rotor temperature time constant
	real tau_T2 = 1756.000476 {s};					/ / stator temperature time constant
*/
	integer hidden Type = 6;				// Brushless DC
	// Temperature dependencies
	real alpha_c = 0.004; 					// temperature coefficient of resistivity of copper
	real ktc = 0;				// temperature coefficient of torque constant
	real R_25 = 1.34 {ohm}; 				// terminal resistance phase-phase at 25 C 
	// electrical part
	real L = 0.000435 {H}; 					// terminal inductance phase-phase
	real fh = 2000.0 {Hz};					// differentiation limit Hz
	// mechanical part
	real J_rotor = 1.3e-005 {kg.m2/rad};			// rotor inertia
	real T_fric = 0.00365 {N.m}; 				// friction and hysteresis
	real d = 9.54929e-006 {N.m.s/rad};				// damping and eddy currents
	real T_cog = 0 {N.m};					// cogging force
	real poles = 0 {};					// number of poles (one pole pair = 2 poles)
	// thermal part
   	real RT1 = 1.35 {K/W}; 					// thermal resistance (coil to housing)
   	real CT1 = 21.4815 {J/K};					// thermal capacity of coil
   	real RT2 = 1.773 {K/W}; 					// thermal resistance (housing to environment)
   	real CT2 = 990.412 {J/K};					// thermal capacity of housing
	real Temp_amb = 25 {degC}; 				// ambient temperature
	real Temp_initial = 25 {degC};			// starting temperature of the motor coils 
	real Temp_max = 125 {degC}; 				// maximum temperature of the motor coils
	// torque speed plotting
	real T_max = 1.584 {N.m}; 				// maxium shaft torque at near zero speeds
	real omega_max = 606.32738214283 {rad/s};				// maximum motor speed
	real U_rms_max = 36 {V}; 				// maximum motor voltage
	real I_rms_max = 26.8657 {A}; 				// maximum motor current
	real P_max = 210 {W};					// maximum power	
	real I_rms_nom = 3.63 {A}; 				// nominal motor current
	real T_nom = 0.2004 {N.m}; 				// nominal shaft torque
	real omega_nom = 1047.1975511966 {rad/s};				// nominal motor speed
variables
	// DYNAMICS
	// temperature dependencies
	real R {ohm};						// terminal resistance phase-phase at 25 C at simulated temperature
	real K {N.m/A};						// torque constant at simulated temperature
	real K_nom {N.m/A};					// torque constant at 25 C at nominal current
	real K_max {N.m/A};					// torque constant at 25 C at maximum current
	// electrical part
	real hidden di_dt {A};					// derivative of the current
	real u_tt_ff {V};					// maximum terminal (phase-phase) voltage
	real hidden rate;
	real hidden initial_input;
	boolean hidden initialized;
	// mechanical part
	real phi {rad};						// shaft angle
	real hidden T_m {N.m};					// motor torque
	real hidden T_f {N.m};					// friction, damping, hysteresis and eddy currents torque
	real hidden T_J {N.m};					// motor inertia torque 
	real T_abs {N.m};					// absolute value of the output torque
	real omega_abs {rad/s};					// absolute value of the output angular velocity
	// thermal part
	real Temp_coil {degC};					// coil temperature
	real Temp_housing {degC};				// housing temperature
	real hidden dQ_el {W}; 					// heat generated by the coils
	real hidden dQ_mech {W}; 				// heat generated by friction, damping, hysteresis and eddy currents torque
	real hidden dQ_coil_housing {W};	 		// heat flow from coil to housing
	real hidden dQ_housing_amb {W}; 			// heat flow from housing to ambient
	// torque speed plotting
	real simulation_time {s};				
	real omega_range {rad/s};				// speed ranging from zero to over 5% of maximum speed
	real T_range {N.m};					// torque ranging from zero to over 5% of maximum torque
	real Torquemax {N.m};					// maximum torque
	real Speedmax {rad/s};					// maximum speed
	real T_max_power {N.m};					// torque at maximum power
	real T_max_current {N.m};				// torque at maximum current
	real T_max_outputpower {N.m};				// line of maxiumum output torque
	real T_max_voltage {N.m};				// torque at maximum voltage
	real T_max_efficiency {N.m};				// torque at maximum efficiency as function of "vrange"
	real hidden R_work {ohm};				// resistance at working temperature
	real hidden K_work {N.m/A};				// torque constant at working temperature
	real hidden S_work {N.m.s/rad};				// steepness at working temperature 
	real hidden S_max {N.m.s/rad};				// steepness at maximum temperature 
	real hidden K_maxT {N.m/A};				// torque constant at maximum temperature
	real hidden R_max {ohm};				// resistance at maxium temperature
	real hidden K_temp {N.m/A};				// torque constant with temperature compensation
	real hidden K_fall {N.m/A};				// decrease of torque constant for high currents
	real hidden P_100 {W};					// generated heat for maximum allowable continuous torque, (i.e. a 100% duty cycle )
	real T_100 {N.m};					// maximum allowable continuous torque, (i.e. a 100% duty cycle )
	real T_50 {N.m};					// maximum allowable torque for a 50% duty cycle 
	real T_25 {N.m};					// maximum allowable torque for a 25% duty cycle 
	real T_10 {N.m};					// maximum allowable torque for a 10% duty cycle 
initialequations
	initialized = false;
	// plot stuff
	simulation_time = finishtime - starttime;
	// nominal and maximum torque constant
	K_nom = (T_nom + T_fric + d*omega_nom)/I_rms_nom;
	K_max = T_max/I_rms_max;
	// parameters at working temperature
	R_work = (R_25 * (1+ alpha_c * (Temp_initial - 25))); 	
	K_work = (K_nom * (1 + ktc * (Temp_initial - 25))); 	
	S_work = (K_work^2)/R_work;
	// parameters at maximum temperature
	R_max = (R_25 * (1+ alpha_c * (Temp_max - 25))); 	
	K_maxT = (K_nom * (1 + ktc * (Temp_max - 25))); 	
	S_max = (K_maxT^2)/R_max;
equations
	// DYNAMICS
	// voltage
	if not initialized then 
		initial_input = i; 
		initialized = true;
	end;
	rate = -2*pi*fh * di_dt;
	di_dt = 2*pi*fh * (i - initial_input) + int (rate,0); 
	u_tt_ff = R*i + L*di_dt + K*p.omega;
	// heat generated by the coils
	dQ_el = R*i^2; 							
	// mechanical part
	T_m = K * i;
	T_f = T_fric * tanh(1000 * p.omega) + d * p.omega + T_cog*sin(poles/2*phi);
	T_J = T_m - T_f - p.T;
	p.omega = int (T_J/J_rotor);
	phi = int(p.omega);
	// heat generated by magnetic hysteresis and friction
	dQ_mech = T_f * p.omega; 	
	// thermal part
	// temperature dependency of coils (copper)
	R = (R_25 * (1+ alpha_c * (Temp_coil - 25))); 	
	// temperature and current dependency of torque constant
	K_temp = (K_nom * (1 + ktc * (Temp_housing - 25))); 	
	K_fall = if I_rms_max == I_rms_nom then 0 else (K_temp - K_max)*(abs(i) - I_rms_nom)^2 / (I_rms_max - I_rms_nom)^2 end;
	K = if abs(i) < I_rms_nom then 
			K_temp
		else
			if K_fall < K_temp then 
				K_temp - K_fall
			else
				0
			end
		end;
	// temperatures
	Temp_coil = (1/CT1) * int(dQ_el + dQ_mech - dQ_coil_housing) + Temp_initial;
	dQ_coil_housing = (Temp_coil - Temp_housing)/RT1;
	// T_work = coil temperature. Stator temperature based on steady state: heat flow is constant
	// and keeps coil temperature at T_work: prs_dQ = pse_dQ -> (T_work - Ts)/Rt1 = (Ts - T_amb)/Rt2 ->
	// Ts = (T_work*Rt2 + T_amb*Rt1)/(Rt1+Rt2)
	Temp_housing = (1/CT2) * int(dQ_coil_housing - dQ_housing_amb) + Temp_initial;	
	dQ_housing_amb = (Temp_housing - Temp_amb)/RT2;
	T_abs = abs (p.T);
	omega_abs = abs(p.omega);
	// TORQUE SPEED PLOT
	// speed ranging from zero to over 5% of maximum speed
	omega_range = time*(1.05*omega_max/simulation_time);
	// torque ranging from zero to over 5% of maximum torque
	T_range = time*(1.05*T_max/simulation_time);
	// Maximum allowed motor torque
	Torquemax = T_max - d*omega_range;
	// Maximum allowed motor speed
	Speedmax = 1.0*omega_max;	
	// torque at maximum current
	T_max_current = K_max * I_rms_max - (d*omega_range + T_fric);
	// torque at maximum voltage
	T_max_voltage = limit( S_work*(U_rms_max / K_work - omega_range) - d*omega_range - T_fric, 0, Torquemax);
	// torque at maximum output power
	T_max_power = if omega_range == 0 then
			Torquemax
		else
			limit(P_max / omega_range - (d*omega_range + T_fric), 0, Torquemax)
		end;
	// line of torque for maximum output power
	T_max_outputpower = limit( omega_range*(S_work + d),0,Torquemax);
	// line of torque for maximum efficiency
	T_max_efficiency = limit(S_work*sqrt((omega_range*(T_fric + d*omega_range))/(S_work + d) ) - T_fric - d*omega_range,0,Torquemax);
	// duty cycles
  	P_100 = ((Temp_max - Temp_amb) / (RT1 + RT2));
	T_100 = limit(sqrt(S_max*limit(P_100 - omega_range*T_fric - d*omega_range^2,0,P_100)) -T_fric - d*omega_range,0,T_max); 
	T_50 = T_100/sqrt(0.5);
	T_25 = T_100/sqrt(0.25);
	T_10 = T_100/sqrt(0.1);implementation_end;
   Transmission 424 152.8
			specifications active 'Ideal'
				specification 'Efficiency'
 description '<Information>
