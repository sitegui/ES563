 </Description>
</Information>';
 type Transmission
  ports
   rotation psi in p_in;
   rotation psi out p_out;
  restrictions
   orientation constraint not_equal p_in p_out;
   causality constraint not_equal p_in p_out;
 end;
 icon ipm bottom
  figures
   line 56 270.4 71.5 270.4;
   line 71.5 298.6 87.5 298.6;
   line 87.5 270.4 120 270.4;
   group
    line 71.5 282.4 71.5 314.7 width 2;
    line 68.3 282.4 74.7 282.4 width 2;
    line 68.3 314.7 74.7 314.7 width 2;
   end;
   group
    line 71.5 263.1 71.5 275.4 width 2;
    line 68.3 263.1 74.7 263.1 width 2;
    line 68.3 277.4 74.7 277.4 width 2;
   end;
   group
    line 87.5 257.7 87.5 285.7 width 2;
    line 84.3 257.7 90.7 257.7 width 2;
    line 84.3 285.7 90.7 285.7 width 2;
   end;
   group
    line 87.5 292 87.5 306.2 width 2;
    line 84.3 292 90.7 292 width 2;
    line 84.3 306.2 90.7 306.2 width 2;
   end;
   line 68.3 323.3 74.7 323.3 color -1;
   text '1' 62.9 260.3;
   text 'i' 97.1 260.3 color 16711680;
   group
    line 101.7 266.6 105.9 260.6;
    line 101.7 260.6 105.9 266.6;
    line 108.1 260.6 112.3 266.6;
    line 108.1 266.6 112.3 260.6;
   end;
   group
    line 101.7 278.7 105.9 272.9;
    line 101.7 272.9 105.9 278.7;
    line 108.1 272.9 112.3 278.7;
    line 108.1 278.7 112.3 272.9;
   end;
  terminals
   p_in 56 270.4 fixed;
   p_out 120 270.4 fixed;
 end;
 implementation eq
parameters
	real i = 10.0 {};				// gearbox ratio
	real eff = 0.97 {};			// gearbox efficiency (0 < eff <= 1)
variables
	real dyn_eff;
initialequations
	dyn_eff = eff;
equations
	p_out.T = p_in.T*i*dyn_eff;
	p_out.omega = p_in.omega/i;
	dyn_eff = if (sign(dly(p_in.T,0.0))*sign(dly(p_in.omega,0.0))) >= 0 then eff else 1/eff end;
	
                     implementation_end;
specification_end;
				specification 'Ideal'
 description '<Information>
 <Description>
    <Version>4.5</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Iconic Diagrams\Mechanical\Rotation\Gears\Transmission.emx</LibraryPath>
  <TimeStamp>2014-9-26 12:20:30</TimeStamp>
<AllowLibraryUpdate>True</AllowLibraryUpdate>
  <Configuration>
   <struct>
    <member>
     <name>DocumentationMask</name>
