    line 165 502.7 165 524.7 width 2;
    line 161.8 502.7 168.2 502.7 width 2;
    line 161.8 524.7 168.2 524.7 width 2;
   end;
   group
    line 165 529.5 165 540.6 width 2;
    line 161.8 529.5 168.2 529.5 width 2;
    line 161.8 540.6 168.2 540.6 width 2;
   end;
   line 145.8 554.1 152.2 554.1 color -1;
   text '1' 141.4 504.9;
   text 'i' 172.3 497.7 color 16711680;
  terminals
   p_in 88 512.8 fixed;
   p_out 192 512.8 fixed;
 end;
 implementation eq
parameters
	real i = 10.0 {};					// gearbox ratio
	real eff = 0.97 {};					// gearbox efficiency (0 < eff <= 1)
	real J = 1.0e-5 {kg.m2/rad};		// rotational inertia
variables
	real p_in_T;
	real dyn_eff;
initialequations
	dyn_eff = eff;
equations
	p_in.omega = (1/J)*int(p_in.T - p_in_T);
	p_out.T = p_in_T*i*dyn_eff;
	p_out.omega = p_in.omega/i;
	dyn_eff = if (sign(dly(p_in_T,0.0))*sign(dly(p_in.omega,0.0))) >= 0 then eff else 1/eff end;
implementation_end;
specification_end;
			end;
  end;
  connections
   ServoMotor1\p => Transmission\p_in;
   Transmission\p_out => BeltPulley\p_rot;
   BeltPulley\p_trans => Mass\p;
   Mass\p => PositionSensor\p;
   Cycloid\output -> PlusMinus\plus;
   PlusMinus\output -> PID\error;
   PID\output -> ServoMotor1\i;
   PositionSensor\x -> PlusMinus\minus 176 272;
  end;
 implementation_end;
]]>
