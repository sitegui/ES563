<?xml version="1.0" encoding="UTF-8"?>
<Document>
  <Icons>
    <Icon size="128" bpp="32" format="png">
<![CDATA[]]>
     </Icon>
  </Icons>
  <Model version="4.2" build="4.2.0.14">
    <Sidops>
<![CDATA[ServoMotor 128 128 description '<Information>
 <Description>
    <LibraryPath>Iconic Diagrams\Mechanical\Rotation\Actuators\ServoMotor.emx</LibraryPath>
  <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
  <AllowLibraryUpdate>True</AllowLibraryUpdate>
    <TimeStamp>2011-12-9 13:03:04</TimeStamp>
</Description>
</Information>'; type ServoMotor  ports   rotation psi out p;   signal in i {A} ;  restrictions   causality fixed in p; end; icon bg bottom  figures   rectangle 547.8 406.8 596.4 439.9 fill 11788799 dashed;   text 'Mask' 584.4 434.1;   rectangle 588.3 414.5 604.6 417.7 fill 15132390;   rectangle 540.8 399.5 588.8 432 fill 15132390;   line 584 399.5 584 432 fill 15132390;   rectangle 588.8 402.2 592 428.3 fill 15132390;   text 'Editor' 563.6 422.1 color 16711680 14;   text 'Motor' 563.6 407.9 color 16711680 14;  terminals   p 606.7 416.3 fixed;   i 538.7 415.3 fixed; end; implementation eq// 20-sim User Editor// MotorWizard.dll// ServoMotor.csvconstants	string Name = 'Maxon RE 13';				// name of motor	string Keyname = '118588';			// keyname of motor	string Info = 'graphite brushes';				// info of motor/*		string Date = '31-Oct-05';				/ / Date of entry*/parameters/*	real Price = 0 {euro};				/ / Price in Euro	string Delivery_time = '0' {weeks};			/ / Delivery Time	real U_rms_nom = 5.877558302 {V}; 				/ / nominal motor voltage	real P_nom = 2.029932876 {W};					/ / nominal power	real Life_nom = 0 {hour};				/ / nominal Lifetime	real F_axial = 0.8 {N};					/ / maximum axial force	real F_radial = 1.4 {N};				/ / maximum radial force	real m = 0.023{kg};					/ / motor mass	real D_motor = 0.013 {m};					/ / motor diameter	real L_motor = 0.0345 {m};					/ / motor length	real D_shaft = 0.0015 {m};				/ / shaft diameter	real L_shaft = 0.006 {m};				/ / shaft length	real T_100 = 0 {N.m};					/ / maximum torque at 100% duty cycle	real S = 1.254495483897e-005 {N.m.s/rad};				/ / motor steepness	real K_nom = 0.0066563887906389 {N.m/A};				/ / torque constant at nom current	real K_max = 0.0050406083260189 {N.m/A};				/ / torque constant at max current	real tau_m = 0.0038542426513806 {s};					/ / mechanical time constant	real tau_e = 3.1144719672569e-005 {s};					/ / electrical time constant	real P_dis = 0 {W};					/ / dissipated internal power	real tau_T1 = 4.55 {s};					/ / rotor temperature time constant	real tau_T2 = 379.5 {s};					/ / stator temperature time constant*/	integer hidden Type = 3;				// Brush DC moving coil	// temperature dependencies	real alpha_c = 0.00392; 					// temperature coefficient of resistivity of copper	real ktc = -0.00105;						// temperature coefficient of torque constant	real R_25 = 3.531898863 {ohm}; 					// resistance at 25 C 	// electrical part	real L = 0.00011 {H}; 					// inductance	real fh = 2000.0 {Hz};					// differentiation limit	// mechanical part	real J_rotor = 4.83513e-008 {kg.m2/rad};	// rotor inertia	real T_fric = 0.0002203 {N.m}; 				// friction and and hysteresis	real d = 1.112e-007 {N.m.s/rad};			// damping and eddy currents	real T_cog = 0 {N.m};				// cogging force	real poles = 2 {};					// number of poles (one pole pair = 2 poles)	// thermal part	real RT1 = 7 {K/W}; 				// thermal resistance (coil to housing)	real CT1 = 0.65 {J/K};					// thermal capacity of coil	real RT2 = 33 {K/W}; 				// thermal resistance (housing to environment)	real CT2 = 11.5 {J/K};				// thermal capacity of housing	real Temp_amb = 25 {degC}; 			// ambient temperature	real Temp_initial = 25 {degC};		// starting temperature of the motor coils 	real Temp_max = 85 {degC};			// maximum temperature of the motor coils	// torque speed plotting	real T_max = 0.0102756 {N.m};					// maxium shaft torque at near zero speeds	real omega_max = 1675.5160819146 {rad/s};		// maximum motor speed	real U_rms_max = 9.550937882 {V};				// maximum motor voltage	real I_rms_max = 2.03856347 {A};				// maximum motor current	real P_max = 3 {W};					// maximum power		real I_rms_nom = 0.587121955 {A};				// nominal motor current	real T_nom = 0.002959452 {N.m};					// nominal shaft torque	real omega_nom = 685.91439603377 {rad/s};			// nominal motor speedvariables	// DYNAMICS	// temperature dependencies	real R {ohm};							// resistance at simulated temperature	real K {N.m/A};							// torque constant at simulated temperature	real K_nom {N.m/A};						// torque constant at 25 degC at nominal current	real K_max {N.m/A};						// torque constant at 25 degC at maximum current	// electrical part	real hidden di_dt {A};					// derivative of the current	real u {V};								// maximum voltage	real hidden rate;	real hidden initial_input;	boolean hidden initialized;	// mechanical part	real phi {rad};							// shaft angle	real hidden T_m {N.m};					// motor torque	real hidden T_f {N.m};					// friction, damping, hysteresis and eddycurrents torque	real hidden T_J {N.m};					// motor inertia torque 	// thermal part	real Temp_coil {degC};					// coil temperature	real Temp_housing {degC};				// housing temperature	real hidden dQ_el {W}; 					// heat generated by the coils	real hidden dQ_mech {W}; 				// heat generated by friction, damping, hysteresis and eddycurrents torque	real hidden dQ_coil_housing {W}; 		// heat flow from coil to housing	real hidden dQ_housing_amb {W}; 		// heat flow from housing to ambient	real T_abs {N.m};						// absolute torque	real omega_abs {rad/s};					// absolute velocity	// TORQUE SPEED PLOT	real simulation_time {s};				// simulation time needed for plotting	real omega_range {rad/s};				// speed ranging from zero to over 5% of maximum speed	real T_range {N.m};						// torque ranging from zero to over 5% of maximum torque	real Torquemax {N.m};					// maximum torque	real Speedmax {rad/s};					// maximum speed	real T_max_power {N.m};					// torque at maximum power	real T_max_current {N.m};				// torque at maximum current	real T_max_outputpower {N.m};			// line of maxiumum output torque	real T_max_voltage {N.m};				// torque at maximum voltage	real T_max_efficiency {N.m};			// torque at maximum efficiency as function of "vrange"	real hidden R_work {ohm};				// resistance at working temperature	real hidden K_work {N.m/A};				// torque constant at working temperature	real hidden S_work {N.m.s/rad};			// steepness at working temperature 	real hidden S_max {N.m.s/rad};			// steepness at maximum temperature 	real hidden K_maxT {N.m/A};				// torque constant at maximum temperature	real hidden R_max {ohm};				// resistance at maxium temperature	real hidden K_temp {N.m/A};				// torque constant with temperature compensation	real hidden K_fall {N.m/A};				// decrease of torque constant for high currents	real hidden P_100 {W};					// generated heat for maximum allowable continuous torque, (i.e. a 100% duty cycle )	real T_100 {N.m};						// maximum allowable continuous torque, (i.e. a 100% duty cycle )	real T_50 {N.m};						// maximum allowable torque for a 50% duty cycle 	real T_25 {N.m};						// maximum allowable torque for a 25% duty cycle 	real T_10 {N.m};						// maximum allowable torque for a 10% duty cycle initialequations	initialized = false;	// plot stuff	simulation_time = finishtime - starttime;	// nominal and maximum torque constant	K_nom = (T_nom + T_fric + d*omega_nom)/I_rms_nom;	K_max = T_max/I_rms_max;	// parameters at working temperature	R_work = (R_25 * (1+ alpha_c * (Temp_initial - 25))); 		K_work = (K_nom * (1 + ktc * (Temp_initial - 25))); 		S_work = (K_work^2)/R_work;	// parameters at maximum temperature	R_max = (R_25 * (1+ alpha_c * (Temp_max - 25))); 		K_maxT = (K_nom * (1 + ktc * (Temp_max - 25))); 		S_max = (K_maxT^2)/R_max;equations	// DYNAMICS	// voltage	if not initialized then 		initial_input = i; 		initialized = true;	end;	rate = -2*pi*fh*di_dt;	di_dt = 2*pi*fh*(i - initial_input) + int (rate,0); 	u = R*i + L*di_dt + K*p.omega;	// heat generated by the coils	dQ_el = R*i^2; 								// mechanical part	T_m = K * i;	T_f = T_fric * tanh(1000 * p.omega) + d * p.omega + T_cog*sin(poles/2*phi);	T_J = T_m - T_f - p.T;	p.omega = int (T_J/J_rotor);	phi = int(p.omega);	T_abs = abs(p.T);	omega_abs = abs(p.omega);	// heat generated by magnetic hysteresis and friction	dQ_mech = T_f * p.omega; 		// thermal part	// temperature dependency of coils (copper)	R = (R_25 * (1+ alpha_c * (Temp_coil - 25))); 		// temperature and current dependency of torque constant	K_temp = (K_nom * (1 + ktc * (Temp_housing - 25))); 		K_fall = if I_rms_max == I_rms_nom then 0 else (K_temp - K_max)*( abs(i) - I_rms_nom)^2 / (I_rms_max - I_rms_nom)^2 end;	K = if abs(i) < I_rms_nom then 			K_temp		else			if K_fall < K_temp then 				K_temp - K_fall			else				0			end		end;	// temperatures	Temp_coil = (1/CT1) * int(dQ_el + dQ_mech - dQ_coil_housing ) + Temp_initial;	dQ_coil_housing = (Temp_coil - Temp_housing)/RT1;	Temp_housing = (1/CT2) * int(dQ_coil_housing - dQ_housing_amb) + Temp_initial;		dQ_housing_amb = (Temp_housing - Temp_amb)/RT2;	// TORQUE SPEED PLOT	// speed ranging from zero to over 5% of maximum speed	omega_range = time*(1.05*omega_max/simulation_time);	// torque ranging from zero to over 5% of maximum torque	T_range = time*(1.05*T_max/simulation_time);	// maximum torque	Torquemax = T_max - d*omega_range;	// maximum speed	Speedmax = 1.0*omega_max;		// torque at maximum current	T_max_current = K_max * I_rms_max - (d*omega_range + T_fric);	// torque at maximum voltage	T_max_voltage = limit( S_work*(U_rms_max / K_work - omega_range) - d*omega_range - T_fric, 0, Torquemax);	// torque at maximum output power	T_max_power = if omega_range == 0 then			Torquemax		else			limit(P_max / omega_range - (d*omega_range + T_fric), 0, Torquemax)		end;	// line of torque for maximum output power	T_max_outputpower = limit( omega_range*(S_work + d),0,Torquemax);	// line of torque for maximum efficiency	T_max_efficiency = limit(S_work*sqrt( (omega_range*(T_fric + d*omega_range))/(S_work + d) ) - T_fric - d*omega_range,0,Torquemax);	// duty cycles  	P_100 = ((Temp_max - Temp_amb) / (RT1 + RT2));	T_100 = limit(sqrt( S_max*limit(P_100 - omega_range*T_fric - d*omega_range^2,0,P_100)) -T_fric - d*omega_range,0,T_max); 	T_50 = T_100/sqrt(0.5);	T_25 = T_100/sqrt(0.25);	T_10 = T_100/sqrt(0.1);implementation_end;]]>
    </Sidops>
  </Model>
</Document>
