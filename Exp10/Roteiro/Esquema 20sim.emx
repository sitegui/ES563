    real tau1 = 1;		// time constant 1 [s / rad]
	real tau2 = 1;		// time constant 2 [s / rad]
variables
    	real hidden rate1,rate2, state1;
	real state2;
equations
	rate1 = (k * input - state1) / tau1;
