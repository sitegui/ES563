    icon bg bottom
     figures
      rectangle 528 264 560 296 fill 15132390;
      line 530.9 288 557.1 288;
      line 533.3 287.8 537.7 288.1 551.1 275.4 color 16711680 width 2;
      line 533.1 272 533.1 290.2;
    end;
    implementation eq
parameters
	real slope = 1 {1/s};
	real start_time = 1.0 {s};
variables
	boolean hidden change;
equations
	"calculate at least at the start time"
	change = timeevent (start_time);

	"calculate the ramp signal"
	output = slope * ramp (start_time);
     implementation_end;
