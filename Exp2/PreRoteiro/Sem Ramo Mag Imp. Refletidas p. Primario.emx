  ports
   electric delta out p;
  restrictions
   causality fixed out p;
 end;
 icon bg bottom
  figures
   group
    line 136 219 136 227;
    line 132 223 140 223;
   end;
   line 144 216 144 264;
   ellipse 132.9 229.3 155.3 251.7 fill 16777215;
   spline 136.1 239.8 141.4 234.2 146.7 245.2 151.9 239.8;
  terminals
   p high 144 216 fixed;
   p low 144 264 fixed;
 end;
 implementation eq
parameters
	real U = 220 {V};		// voltage
	real f = 60.0 {Hz};			// frequency
variables
	real hidden current {A};
equations
	p.u = U * sin ( 2 * pi * f * time );
   	current = p.i;implementation_end;
specification_end;
				specification 'DC'
