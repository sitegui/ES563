 description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Iconic Diagrams\Electric\Components\Transformer.emx</LibraryPath><TimeStamp>2007-9-25 11:58:38</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate><Configuration><struct><member><name>DocumentationMask</name><value><struct></struct></value></member></struct></Configuration></Description></Information>';
 type Transformer
  ports
   electric delta in p_1;
   electric delta out p_2;
  restrictions
   causality constraint not_equal p_1 p_2;
 end;
 icon ipm bottom
  figures
   group
    line 421.3 225.4 421.3 269.2;
    line 426.7 225.4 426.7 269.2;
   end;
   text 'n : 1' 423 214 color 16711680 14;
   line 408 224 416 224 416 272 408 272;
   line 440 272 432 272 432 224 440 224;
  terminals
   p_1 high 408 224 fixed;
   p_1 low 408 272 fixed;
   p_2 high 440 224 fixed;
   p_2 low 440 272 fixed;
 end;
 implementation eq
parameters
	real n = 2.0 {};		// turns ratio []
equations
	p_1.u = n * p_2.u;
	p_2.i = n * p_1.i;           implementation_end;
specification_end;
				specification 'induction'
description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
  <LibraryPath>Iconic Diagrams\Electric\Components\Transformer.emx</LibraryPath>
  <TimeStamp>2007-9-24 20:22:16</TimeStamp>
</Description>
';
 library_path 'Iconic Diagrams\Electric\Components\Transformer.emx';
 type Transformer
  ports
   electric delta in p_1;
   electric delta out p_2;
  restrictions
   causality constraint not_equal p_1 p_2;
 end;
 icon ipm bottom
  figures
   line 109 84.7 109 124.7;
   line 115 84.7 115 124.7;
   ellipse 100 88 108 96;
   ellipse 100 96 108 104;
   ellipse 100 104 108 112;
   ellipse 100 112 108 120;
   ellipse 116 88 124 96;
   ellipse 116 96 124 104;
   ellipse 116 104 124 112;
   ellipse 116 112 124 120;
   rectangle 120.5 87.7 125.7 121 color -1 fill 16777215;
   rectangle 97.8 87.5 103.2 120.8 color -1 fill 16777215;
   line 128 80 120 80 120 88;
   line 128 128 120 128 120 120;
   line 96 128 104 128 104 120;
   line 96 80 104 80 104 88;
  terminals
   p_1 high 96 80 fixed;
   p_1 low 96 128 fixed;
   p_2 high 128 80 fixed;
   p_2 low 128 128 fixed;
 end;
 implementation eq
parameters
	real M {H};		// coupling inductance
	real L1 {H};		// primary inductance
	real L2 {H};		// secondary inductance
equations
	p_1.u = L1*ddt (p_1.i) +  M * ddt (p_2.i);
  	p_2.u = M *ddt (p_1.i) + L2 * ddt (p_2.i);              implementation_end;
specification_end;
			end;
